{
  "name": "criticseven",
  "version": "0.1.0",
  "description": "Movie Rating Application",
  "author": "Henry Cuffy",
  "license": "MIT",
  "private": false,
  "main": "./server.js",
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "packageManager": "pnpm@11.10.0",
  "scripts": {
    "build": "pnpm clean && pnpm transpile",
    "clean": "rimraf dist-server",
    "client": "pnpm --filter criticseven-client start",
    "debug:dev": "NODE_ENV=development DEBUG=criticseven:* pnpm build && pnpm server",
    "dev": "NODE_ENV=development pnpm build && pnpm server",
    "heroku-postbuild": "pnpm --filter criticseven-client build",
    "prod": "NODE_ENV=production pnpm build && pnpm server",
    "server": "node ./dist-server/index",
    "start": "pnpm prod",
    "start:dev": "concurrently \"pnpm dev\" \"pnpm client\"",
    "start:prod": "concurrently \"pnpm prod\" \"pnpm client\"",
    "test": "jest -i",
    "transpile": "babel ./server --out-dir dist-server",
    "watch:dev": "nodemon"
  },
  "dependencies": {
    "@babel/runtime": "^8.0.0",
    "axios": "^1.18.1",
    "concurrently": "^10.0.3",
    "cookie-parser": "^1.4.7",
    "debug": "~4.4.3",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "lodash": "^4.18.1",
    "mongoose": "^9.7.3",
    "morgan": "~1.11.0"
  },
  "devDependencies": {
    "@babel/cli": "^8.0.1",
    "@babel/core": "^8.0.1",
    "@babel/node": "^8.0.1",
    "@babel/plugin-transform-runtime": "^8.0.1",
    "@babel/preset-env": "^8.0.2",
    "@babel/preset-flow": "^8.0.1",
    "babel-eslint": "^10.1.0",
    "babel-jest": "^30.4.1",
    "eslint": "^10.6.0",
    "eslint-config-airbnb": "^19.0.4",
    "eslint-config-node": "^4.1.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-flowtype": "^8.0.3",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-jest": "^29.15.4",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-node": "^11.1.0",
    "eslint-plugin-prettier": "^5.5.6",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "flow-bin": "^0.321.0",
    "jest": "^30.4.2",
    "nodemon": "^3.1.14",
    "prettier": "^3.9.4",
    "rimraf": "^6.1.3"
  },
  "nodemonConfig": {
    "exec": "pnpm dev",
    "watch": [
      "server/*"
    ]
  }
}
