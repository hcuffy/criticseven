{
  "name": "criticseven",
  "version": "0.1.0",
  "description": "Movie Rating Application",
  "author": "Henry Cuffy",
  "license": "MIT",
  "private": false,
  "main": "./server.js",
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "packageManager": "pnpm@10.34.5",
  "scripts": {
    "build": "pnpm clean && pnpm transpile",
    "clean": "rimraf dist-server",
    "client": "pnpm --filter criticseven-client start",
    "debug:dev": "NODE_ENV=development DEBUG=criticseven:* pnpm build && pnpm server",
    "dev": "NODE_ENV=development pnpm build && pnpm server",
    "heroku-postbuild": "pnpm --filter criticseven-client build",
    "prod": "NODE_ENV=production pnpm build && pnpm server",
    "server": "node ./dist-server/index",
    "start": "pnpm prod",
    "start:dev": "concurrently \"pnpm dev\" \"pnpm client\"",
    "start:prod": "concurrently \"pnpm prod\" \"pnpm client\"",
    "test": "jest -i",
    "transpile": "babel ./server --out-dir dist-server",
    "watch:dev": "nodemon"
  },
  "dependencies": {
    "@babel/runtime": "7.29.7",
    "axios": "1.18.1",
    "concurrently": "5.1.0",
    "cookie-parser": "1.4.7",
    "debug": "4.4.3",
    "dotenv": "8.2.0",
    "express": "4.22.2",
    "lodash": "4.18.1",
    "mongoose": "8.24.1",
    "morgan": "1.11.0"
  },
  "devDependencies": {
    "@babel/cli": "7.29.7",
    "@babel/core": "7.29.7",
    "@babel/node": "7.29.7",
    "@babel/plugin-transform-runtime": "7.29.7",
    "@babel/preset-env": "7.29.7",
    "babel-eslint": "10.1.0",
    "babel-jest": "30.4.1",
    "eslint": "6.8.0",
    "eslint-config-airbnb": "18.1.0",
    "eslint-config-node": "4.1.0",
    "eslint-config-prettier": "6.10.1",
    "eslint-plugin-import": "2.32.0",
    "eslint-plugin-jest": "23.8.2",
    "eslint-plugin-jsx-a11y": "6.10.2",
    "eslint-plugin-node": "11.1.0",
    "eslint-plugin-prettier": "3.1.2",
    "eslint-plugin-react": "7.37.5",
    "eslint-plugin-react-hooks": "2.5.0",
    "jest": "30.4.2",
    "nodemon": "3.1.14",
    "prettier": "2.0.2",
    "rimraf": "3.0.2"
  },
  "nodemonConfig": {
    "exec": "pnpm dev",
    "watch": [
      "server/*"
    ]
  }
}
